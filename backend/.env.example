# CraftVerse 后端服务器配置
# 复制此文件为 .env 并填写你的配置

# 服务器端口
PORT=3000

# JWT 密钥（修改为随机字符串）
JWT_SECRET=craftverse_jwt_secret_change_me_3.14159

# 数据库文件路径
DB_PATH=./data/craftverse.db

# QQ 邮箱 SMTP 配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code

# 管理员密码（默认为 π 精确值）
ADMIN_PASSWORD=3.141592653589793238462643383279501

# Microsoft OAuth（可选 - 需在 Azure 注册应用）
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/oauth/microsoft/callback

# QQ OAuth（可选 - 需在 QQ 互联注册）
QQ_APP_ID=
QQ_APP_KEY=
QQ_REDIRECT_URI=http://localhost:3000/api/auth/oauth/qq/callback

# SMS 配置（可选 - 需短信服务商）
SMS_PROVIDER=
SMS_API_KEY=
